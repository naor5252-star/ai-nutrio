{
  "name": "ai-nutrition-advisor-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --config vite.preview.config.mjs",
    "deploy": "npm run build && wrangler deploy",
    "cf-types": "wrangler types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:migrations": "node scripts/validate-migrations.mjs",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run validate:migrations && npm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.83.0",
    "hono": "^4.8.10",
    "idb": "^8.0.3",
    "jose": "^6.0.12",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.7.1",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.9.6",
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vitest": "^4.1.10",
    "wrangler": "^4.26.0"
  }
}
